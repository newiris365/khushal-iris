# ==========================================
# IRIS 365 Unified Environment Template
# ==========================================

# --- Express.js Backend Configurations ---
PORT=4000
NODE_ENV=development
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
JWT_SECRET=your-jwt-secret-min-32-chars-at-least

# Razorpay Payment Integration Credentials
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# AI Assistant Providers (Optional, fallback to mock DB query is supported)
OPENAI_API_KEY=sk-your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# WhatsApp Webhook Verification and Notifications API
WHATSAPP_VERIFY_TOKEN=your-whatsapp-webhook-verify-token
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_PHONE_NUMBER_ID=your-whatsapp-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-whatsapp-system-user-access-token

# --- Next.js Frontend Configurations (Client-Side) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
NEXT_PUBLIC_API_URL=/api/v1
API_HOST=http://localhost:4000
