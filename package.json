{
  "name": "iris-365",
  "version": "1.0.0",
  "description": "IRIS 365 AI-Powered Campus Operating System - Production Stack",
  "private": true,
  "scripts": {
    "dev": "concurrently -n \"next,express\" -c \"cyan,magenta\" \"next dev\" \"ts-node-dev --project tsconfig.server.json --respawn --transpile-only --no-notify --ignore-watch src/app --ignore-watch src/components --ignore-watch src/lib --ignore-watch .next --ignore-watch node_modules src/server.ts\"",
    "build:frontend": "next build",
    "build:backend": "tsc --project tsconfig.server.json",
    "build": "next build",
    "build:all": "next build && tsc --project tsconfig.server.json",
    "start:frontend": "next start",
    "start:backend": "node dist/server.js",
    "start": "concurrently -n \"next,express\" -c \"cyan,magenta\" \"next start\" \"node dist/server.js\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.6.0",
    "@supabase/supabase-js": "^2.43.4",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20.14.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "client-only": "0.0.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "framer-motion": "^11.2.10",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.383.0",
    "next": "^14.2.3",
    "node-cron": "^3.0.3",
    "papaparse": "^5.5.3",
    "pdfkit": "^0.15.0",
    "postcss": "^8.4.38",
    "razorpay": "^2.9.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.51.5",
    "recharts": "^2.12.7",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.7.5",
    "styled-jsx": "5.1.1",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.5",
    "winston": "^3.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node-cron": "^3.0.11",
    "@types/papaparse": "^5.5.2",
    "@types/pdfkit": "^0.13.4",
    "concurrently": "^8.2.2",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.4",
    "ts-node-dev": "^2.0.0"
  }
}
